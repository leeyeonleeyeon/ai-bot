# --- Telegram ---
TELEGRAM_BOT_TOKEN=put-token-from-BotFather-here

# --- Gemma 4 (OpenAI 호환 엔드포인트) ---
# 권장: 로컬 Ollama (개발) → 전용 GPU + vLLM (운영)
# Ollama 예시: http://localhost:11434
GEMMA_BASE_URL=http://localhost:11434
GEMMA_MODEL=gemma-4
GEMMA_API_KEY=

# --- 저장소 ---
DB_PATH=data/tasks.db
OUTPUT_DIR=data/outputs

# --- e2b 코드 실행 샌드박스 (실행 에이전트 도구) ---
# 미설정 시 executor는 LLM 출력만 반환 (코드 미실행)
E2B_API_KEY=

# --- GitHub 자동 커밋 (선택) ---
# 두 값 모두 채워질 때만 작동.  토큰: contents 쓰기 권한 필요(파인그레인드 PAT 권장)
GITHUB_TOKEN=
GITHUB_REPO=owner/name
GITHUB_BRANCH=main
